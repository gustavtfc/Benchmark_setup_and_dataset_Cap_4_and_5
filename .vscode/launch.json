{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Prepare Test Data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/prepare_test_data.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "python": "${command:python.interpreterPath}"
        },
        {
            "name": "Run Vulnerability Tests",
            "type": "debugpy", 
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test_vulnerability_detection.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "python": "${command:python.interpreterPath}"
        },
        {
            "name": "Analyze Results",
            "type": "debugpy",
            "request": "launch", 
            "program": "${workspaceFolder}/scripts/analyze_detection_capability.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "python": "${command:python.interpreterPath}"
        }
    ]
}
